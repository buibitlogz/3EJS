# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Keep Google Sheets webapp URL for legacy support (can be removed later)
# NEXT_PUBLIC_WEBAPP_URL=https://script.google.com/...

# Set to 'supabase' to use Supabase, 'sheets' to use Google Sheets
DATA_SOURCE=supabase