# ─── Production Environment Variables ────────────────────────────────────────
# Set these in Netlify dashboard: Site Settings → Environment Variables

# REQUIRED: Google Apps Script Web App URL
NEXT_PUBLIC_WEBAPP_URL=https://script.google.com/macros/s/YOUR_WEB_APP_ID/exec

# App Configuration
NEXT_PUBLIC_APP_NAME=3EJS Tech
NEXT_PUBLIC_APP_URL=https://your-netlify-site.netlify.app
NEXT_PUBLIC_SHEET_NAME=3JES_MASTERLIST

# Data Source (use "sheets" for production)
DATA_SOURCE=sheets

# REQUIRED: Generate a secure JWT secret
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-secret-key-min-32-characters